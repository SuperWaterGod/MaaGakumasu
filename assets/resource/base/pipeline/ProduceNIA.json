    "recognition": {
      "type": "TemplateMatch",
      "param": {
        "template": [
          "produce/NIA/activity.png",
          "produce/NIA/chat.png",
          "produce/NIA/Da.png",
          "produce/NIA/go_out.png",
          "produce/NIA/guide.png",
          "produce/NIA/Vi.png",
