{
  "task": [
    {
      "name": "开始培育",
      "entry": "Produce",
      "option": [
        "培育难度",
        "培育偶像",
        "培育次数",
        "使用体力药",
        "跳过选择偶像",
        "启用自动回忆",
        "启用关注租借",
        "跳过准备阶段",
        "卡片选择优先级"
      ],
      "resource": [
        "官服"
      ],
      "default_check": true,
      "doc": "$培育说明",
      "label": "$开始培育"
    }
  ],
  "option": {
    "培育难度": {
      "type": "select",
      "default_case": "REGULAR",
      "cases": [
        {
          "name": "REGULAR",
          "pipeline_override": {
            "ProduceChooseDifficulty": {
              "template": "produce/regular.png"
            }
          }
        },
        {
          "name": "PRO",
          "pipeline_override": {
            "ProduceChooseDifficulty": {
              "template": "produce/pro.png"
            }
          }
        },
        {
          "name": "MASTER",
          "pipeline_override": {
            "ProduceChooseDifficulty": {
              "template": "produce/master.png"
            }
          }
        }
      ],
      "label": "$培育难度"
    },
    "使用体力药": {
      "type": "switch",
      "default_case": "Yes",
      "cases": [
        {
          "name": "Yes",
          "pipeline_override": {
            "ProduceLackAP": {
              "next": "ProduceLackAPRestore"
            }
          }
        },
        {
          "name": "No",
          "pipeline_override": {
            "ProduceLackAP": {
              "next": "ProduceLackAPCancel"
            }
          }
        }
      ],
      "label": "$使用体力药"
    },
    "培育次数": {
      "label": "$培育次数",
      "type": "select",
      "default_case": "1",
      "description": "$培育次数说明",
      "cases": [
        {
          "name": "1",
          "pipeline_override": {
            "ProduceLoop": {
              "max_hit": 1
            }
          },
          "label": "1"
        },
        {
          "name": "2",
          "pipeline_override": {
            "ProduceLoop": {
              "max_hit": 2
            }
          },
          "label": "2"
        },
        {
          "name": "3",
          "pipeline_override": {
            "ProduceLoop": {
              "max_hit": 3
            }
          },
          "label": "3"
        },
        {
          "name": "4",
          "pipeline_override": {
            "ProduceLoop": {
              "max_hit": 4
            }
          },
          "label": "4"
        },
        {
          "name": "5",
          "pipeline_override": {
            "ProduceLoop": {
              "max_hit": 5
            }
          },
          "label": "5"
        },
        {
          "name": "6",
          "pipeline_override": {
            "ProduceLoop": {
              "max_hit": 6
            }
          },
          "label": "6"
        },
        {
          "name": "∞",
          "label": "∞"
        },
        {
          "name": "手动输入次数",
          "label": "$手动输入次数",
          "option": [
            "手动输入培育次数"
          ]
        }
      ]
    },
    "手动输入培育次数": {
      "type": "input",
      "inputs": [
        {
          "name": "produce_times",
          "label": "$手动输入培育次数",
          "default": "1",
          "pipeline_type": "int",
          "verify": "^[1-9]\\d*$",
          "pattern_msg": "$手动输入培育次数输入框说明"
        }
      ],
      "pipeline_override": {
        "ProduceLoop": {
          "max_hit": "{produce_times}"
        }
      }
    },
    "启用自动回忆": {
      "type": "switch",
      "default_case": "Yes",
      "cases": [
        {
          "name": "Yes",
          "pipeline_override": {
            "ProduceChooseMemory": {
              "enabled": true
            }
          }
        },
        {
          "name": "No",
          "pipeline_override": {
            "ProduceChooseMemory": {
              "enabled": false
            }
          }
        }
      ],
      "label": "$启用自动回忆"
    },
    "启用关注租借": {
      "type": "switch",
      "default_case": "Yes",
      "cases": [
        {
          "name": "Yes",
          "pipeline_override": {
            "ProduceFollow": {
              "template": "produce/follow.png"
            }
          }
        },
        {
          "name": "No",
          "pipeline_override": {
            "ProduceFollow": {
              "template": "produce/follow.png"
            }
          }
        }
      ],
      "label": "$启用关注租借"
    },
    "跳过准备阶段": {
      "type": "switch",
      "default_case": "No",
      "cases": [
        {
          "name": "Yes",
          "pipeline_override": {
            "ProduceSkipPreparation": {
              "enabled": true
            }
          }
        },
        {
          "name": "No"
        }
      ],
      "label": "$跳过准备阶段"
    },
    "卡片选择优先级": {
      "label": "卡片选择优先级",
      "type": "select",
      "default_case": "建议卡>活动卡",
      "description": "建议卡需要在游戏的培育设置中开启指引才会显示<br>活动卡指仅在「亚纱里老师的制作人讲座」活动中出现的活动卡",
      "cases": [
        {
          "name": "建议卡>活动卡",
          "pipeline_override": {
            "ProduceChooseCards": {
              "attach": {
                "priority": [
                  "suggestion",
                  "event"
                ]
              }
            }
          },
          "label": "$建议卡>活动卡"
        },
        {
          "name": "活动卡>建议卡",
          "pipeline_override": {
            "ProduceChooseCards": {
              "attach": {
                "priority": [
                  "event",
                  "suggestion"
                ]
              }
            }
          },
          "label": "$活动卡>建议卡"
        },
        {
          "name": "无",
          "label": "$无"
        }
      ]
    },
    "跳过选择偶像": {
      "type": "switch",
      "default_case": "No",
      "cases": [
        {
          "name": "Yes",
          "pipeline_override": {
            "ProduceChooseDifficulty": {
              "next": [
                "ProduceLackAP",
                "ProduceChooseIdolNext"
              ]
            }
          }
        },
        {
          "name": "No",
          "pipeline_override": {
            "ProduceChooseDifficulty": {
              "next": [
                "ProduceLackAP",
                "ProduceChooseIdolFlag"
              ]
            }
          }
        }
      ],
      "label": "$跳过选择偶像"
    },
