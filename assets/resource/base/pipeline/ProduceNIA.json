          0,
          800,
          720,
          300
        ]
      }
    },
    "action": {
      "type": "Custom",
      "param": {
        "custom_action": "ProduceChooseNIAEventAuto",
        "custom_action_param": {
          "effect": "非凡·强气",
          "first": "Vo",
          "second": "Vi"
        }
      }
    }
  },
  "ProduceNIAButton": {
    "recognition": {
      "type": "TemplateMatch",
      "param": {
        "template": [
          "next.png", // (必选)考试成功时需要点next
          "produce/retry.png", // 失败时重试
          "produce/decide.png", // 辅助模式似乎必出现
          "produce/skip_confirm.png", // 跳过按钮
          "produce/drink_no.png" // 选择奖励时拒绝饮料
        ],
        "order_by": "Score",
        "roi": [
          0,
          780,
          720,
          500
        ]
      }
    },
    "action": {
      "type": "Click",
      "param": {
        "target_offset": [
          0,
