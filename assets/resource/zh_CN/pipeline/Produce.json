{
    "ProduceChooseIdol": {
        "recognition": {
            "type": "Custom",
            "param": {
                "custom_recognition": "ProduceChooseIdolAuto",
                "custom_recognition_param": {
                    "idol_name": "藤田ことね",
                    "song_name": "雨上がりのアイリス"
                }
            }
        },
        "action": {
            "type": "Click",
            "param": {
                "target": [
                    256,
                    1060,
                    200,
                    64
                ]
            }
        },
        "next": [
            "ProduceChooseSupport"
        ],
        "post_wait_freezes": 200,
        "focus": {
            "Node.Action.Succeeded": "[color:blue]已找到偶像卡[/color]"
        }
    },
    "ProduceButton": {
        "recognition": {
            "type": "TemplateMatch",
            "param": {
                "template": [
                    "next.png", // (必选)考试成功时需要点next
                    "produce/decide.png", // (不确定)在关闭所有可选提示框后，培育阶段没出现过该按钮
                    "produce/yes.png", // (不确定)在关闭所有可选提示框后，培育阶段没出现过该按钮
                    "produce/start.png", // (不确定)在关闭所有可选提示框后，培育阶段没出现过该按钮
                    "produce/close.png", // (可选)误触查看当前持有卡片界面时的关闭按钮，如果解决所有误触情况可以删除
                    "cancel.png", // (可选)REGULAR难度上课失败时，会弹出是否需要进入新手教程的提示框
                    "produce/round_close_button.png" // (不确定)亲爱度up时好像会弹出圆形关闭按钮？不能裁剪，否则会误触商店的离开按钮
                ],
                "order_by": "Score",
                "roi": [
                    0,
                    780,
                    720,
                    500
                ]
            }
        },
        "action": {
            "type": "Click",
            "param": {
                "target_offset": [
                    0,
                    0,
                    0,
                    -10
                ]
            }
        },
        "pre_delay": 100,
        "post_delay": 100
    },
    "ProduceGetDrink": {
        "recognition": {
            "type": "TemplateMatch",
            "param": {
                "template": [
                    "produce/drink_get.png",
                    "produce/cards_get.png"
                ],
                "roi": [
                    0,
                    980,
                    720,
                    300
                ]
            }
        },
        "action": {
            "type": "Click",
            "param": {}
        }
    },
    "ProduceShoppingDecide": {
        "recognition": {
            "type": "TemplateMatch",
            "param": {
                "template": [
                    "produce/shopping_exchange.png",
                    "produce/point_runout.png"
                ],
                "roi": [
                    0,
                    1020,
                    720,
                    260
                ]
            }
        },
        "action": {
            "type": "Click",
            "param": {}
        }
    },
    "ProduceChooseStrengthenFlag": {
        "recognition": {
            "type": "TemplateMatch",
            "param": {
                "template": [
                    "produce/strengthen_icon.png",
                    "produce/exchange_icon.png"
                ],
                "roi": [
                    0,
                    28,
                    182,
                    58
                ]
            }
        },
        "action": {
            "type": "Custom",
            "param": {
                "custom_action": "ProduceStrengthenAuto"
            }
        },
        "pre_delay": 100,
        "post_delay": 100
    },
    "ProduceChooseStrengthen": {
        "recognition": {
            "type": "TemplateMatch",
            "param": {
                "template": "produce/strengthen.png"
            }
        },
        "action": {
            "type": "Click",
            "param": {}
        }
    },
    "ProduceFollow": {
        "recognition": {
            "type": "TemplateMatch",
            "param": {
                "template": "produce/follow.png"
            }
        },
        "action": {
            "type": "Click",
            "param": {}
        }
    },
    "ProduceFailedFlag": {
        "recognition": {
            "type": "TemplateMatch",
            "param": {
                "template": [
                    "produce/exam_failed.png"
                ],
                "roi": [
                    0,
                    700,
                    720,
                    250
                ],
                "threshold": 0.9
            }
        },
        "action": {
            "type": "StopTask",
            "param": {}
        },
        "focus": {
            "Node.Recognition.Succeeded": "考试失败，停止任务"
        }
    }
}