{
  "interface_version": 2,
  "name": "MaaGakumasu",
  "version": "v1.3.8",
  "mirrorchyan_rid": "MaaGakumasu",
  "mirrorchyan_multiplatform": true,
  "github": "https://github.com/SuperWaterGod/MaaGakumasu",
  "contact": "QQ群: 799823681",
  "icon": "./logo.ico",
  "license": "./LICENSE",
  "welcome": "欢迎使用基于全新架构的 学園アイドルマスター(学マス) 小助手。图像技术 + 模拟控制 + 深度学习，解放双手！由 MaaFramework 强力驱动！",
  "description": "学園アイドルマスター（学マス）小助手 | Assistant For Gakuen Idolmaster",
  "languages": {
    "zh-CN": "lang/zh-CN.json",
    "zh-Hant": "lang/zh-Hant.json"
  },
  "controller": [
    {
      "name": "模拟器",
      "type": "Adb"
    },
    {
      "name": "PC",
      "label": "PC",
      "type": "Win32",
      "win32": {
        "class_regex": "UnityWndClass",
        "window_regex": "gakumas",
        "screencap": "PrintWindow",
        "mouse": "SendMessageWithCursorPos",
        "keyboard": "SendMessageWithCursorPos"
      },
      "permission_required": true
    },
    {
      "name": "PlayCover",
      "type": "PlayCover"
    }
  ],
  "resource": [
    {
      "name": "官服",
      "path": [
        "./resource/base"
      ],
      "controller": [
        "模拟器",
        "PlayCover"
      ]
    },
    {
      "name": "插件版汉化",
      "path": [
        "./resource/base",
        "./resource/zh_CN"
      ],
      "controller": [
        "模拟器",
        "PlayCover"
      ]
    },
    {
      "name": "DMM",
      "path": [
        "./resource/base",
        "./resource/DMM"
      ],
      "controller": [
        "PC"
      ]
    },
    {
      "name": "DMM插件汉化版",
      "path": [
        "./resource/base",
        "./resource/zh_CN",
        "./resource/DMM"
      ],
      "controller": [
        "PC"
      ]
    }
  ],
  "agent": {
    "child_exec": "python",
    "child_args": [
      "-u",
      "./../agent/main.py"
    ]
  },
  "import": [
    "./tasks/preset.json",
    "./tasks/shopping.json",
    "./tasks/produce.json",
    "./tasks/produce_cn.json",
    "./tasks/Shutdown.json"
  ],
  "task": [
    {
      "name": "启动游戏",
      "entry": "StartUp",
      "default_check": true,
      "label": "$启动游戏"
    },
    {
      "name": "收取活动费",
      "entry": "ActivityFee",
      "default_check": true,
      "label": "$收取活动费"
    },
    {
      "name": "安排工作",
      "entry": "Work",
      "option": [
        "迷你演唱会Idol",
        "迷你演唱会工作时长",
        "直播活动Idol",
        "直播活动工作时长"
      ],
      "default_check": true,
      "doc": "$安排工作说明",
      "label": "$安排工作"
    },
    {
      "name": "社团活动",
      "entry": "Society",
      "option": [
        "启用捐赠物品",
        "启用请求物品",
        "请求物品种类"
      ],
      "default_check": true,
      "doc": "$社团活动说明",
      "label": "$社团活动"
    },
    {
      "name": "每日挑战",
      "entry": "Challenge",
      "option": [
        "挑战模式"
      ],
      "default_check": true,
      "doc": "$每日挑战说明",
      "label": "$每日挑战"
    },
    {
      "name": "每周免费初星包",
      "entry": "ShoppingPack",
      "default_check": true,
      "doc": "",
      "label": "$每周免费初星包"
    },
    {
      "name": "领取奖励",
      "entry": "Award",
      "option": [
        "启用领取礼物",
        "启用领取任务"
      ],
      "default_check": true,
      "doc": "",
      "label": "$领取奖励"
    }
  ],
  "option": {
    "挑战模式": {
      "type": "select",
      "default_case": "自动",
      "cases": [
        {
          "name": "自动",
          "label": "$自动",
          "pipeline_override": {
            "ChallengeChoose": {
              "custom_action_param": {
                "mode": "auto"
              }
            }
          }
        },
        {
          "name": "最大值",
          "label": "$最大值",
          "pipeline_override": {
            "ChallengeChoose": {
              "custom_action_param": {
                "mode": "max"
              }
            }
          }
        },
        {
          "name": "最小值",
          "label": "$最小值",
          "pipeline_override": {
            "ChallengeChoose": {
              "custom_action_param": {
                "mode": "min"
              }
            }
          }
        },
        {
          "name": "随机",
          "label": "$随机",
          "pipeline_override": {
            "ChallengeChoose": {
              "custom_action_param": {
                "mode": "random"
              }
            }
          }
        },
        {
          "name": "固定第一位",
          "label": "$固定第一位",
          "pipeline_override": {
            "ChallengeChoose": {
              "custom_action_param": {
                "mode": "fixed",
                "index": 0
              }
            }
          }
        },
        {
          "name": "固定第二位",
          "label": "$固定第二位",
          "pipeline_override": {
            "ChallengeChoose": {
              "custom_action_param": {
                "mode": "fixed",
                "index": 1
              }
            }
          }
        },
        {
          "name": "固定第三位",
          "label": "$固定第三位",
          "pipeline_override": {
            "ChallengeChoose": {
              "custom_action_param": {
                "mode": "fixed",
                "index": 2
              }
            }
          }
        }
      ],
      "label": "$挑战模式"
    },
    "迷你演唱会工作时长": {
      "type": "select",
      "default_case": "12 小时",
      "cases": [
        {
          "name": "4 小时",
          "label": "$4 小时",
          "pipeline_override": {
            "WorkChooseShowTime": {
              "expected": "4"
            }
          }
        },
        {
          "name": "8 小时",
          "label": "$8 小时",
          "pipeline_override": {
            "WorkChooseShowTime": {
              "expected": "8"
            }
          }
        },
        {
          "name": "12 小时",
          "label": "$12 小时",
