          "effect": "非凡·强气",
          "first": "Vo",
          "second": "Vi"
        }
      }
    }
  },
  "ProduceNIAButton": {
    "recognition": {
      "type": "TemplateMatch",
      "param": {
        "template": [
          "next.png", // (必选)考试成功时需要点next
          "produce/round_close_button.png", // 试镜解锁后关闭按钮
          "produce/ok.png", // 好感度提升后确认按钮
          "produce/retry.png", // 失败时重试
          "produce/decide.png", // 辅助模式似乎必出现
          "produce/skip_confirm.png", // 跳过按钮
          "produce/drink_no.png", // 选择奖励时拒绝饮料
          "produce/close.png" // ProduceNIAButton识别太快，偶尔会连续识别两次右边的按钮造成误触，然后打开卡包
        ],
        "order_by": "Score",
        "roi": [
          0,
          780,
          720,
          500
        ]
      }
    },
    "action": {
      "type": "Click",
      "param": {
        "target_offset": [
          0,
          0,
          0,
          -10
        ]
      }
    },
    "pre_delay": 100,
    "post_delay": 100
  },
