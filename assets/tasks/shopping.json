{
    "task": [
        {
            "name": "扭蛋兑换",
            "entry": "ShoppingCoinCacha",
            "option": [
                "购买好友扭蛋",
                "购买感性扭蛋",
                "购买理性扭蛋",
                "购买非凡扭蛋",
                "购买活动扭蛋"
            ],
            "default_check": true,
            "doc": "$扭蛋兑换说明",
            "label": "$扭蛋兑换"
        },
        {
            "name": "每日兑换",
            "entry": "ShoppingDailyExchange",
            "option": [
                "启用金币兑换",
                "启用AP兑换"
            ],
            "default_check": true,
            "doc": "$每日兑换说明",
            "label": "$每日兑换"
        }
    ],
    "option": {
        "购买好友扭蛋": {
            "type": "switch",
            "default_case": "Yes",
            "cases": [
                {
                    "name": "Yes",
                    "pipeline_override": {
                        "ShoppingCoinGachaFriendGacha": {
                            "enabled": true
                        }
                    }
                },
                {
                    "name": "No",
                    "pipeline_override": {
                        "ShoppingCoinGachaFriendGacha": {
                            "enabled": false
                        }
                    }
                }
            ],
            "label": "$购买好友扭蛋"
        },
        "购买感性扭蛋": {
            "type": "switch",
            "default_case": "No",
            "cases": [
                {
                    "name": "Yes",
                    "pipeline_override": {
                        "ShoppingCoinGachaSenseGacha": {
                            "enabled": true
                        }
                    }
                },
                {
                    "name": "No",
                    "pipeline_override": {
                        "ShoppingCoinGachaSenseGacha": {
                            "enabled": false
                        }
                    }
                }
            ],
            "label": "$购买感性扭蛋"
        },
        "购买理性扭蛋": {
            "type": "switch",
            "default_case": "No",
            "cases": [
                {
                    "name": "Yes",
                    "pipeline_override": {
                        "ShoppingCoinGachaLogicGacha": {
                            "enabled": true
                        }
                    }
                },
                {
                    "name": "No",
                    "pipeline_override": {
                        "ShoppingCoinGachaLogicGacha": {
                            "enabled": false
                        }
                    }
                }
            ],
            "label": "$购买理性扭蛋"
        },
        "购买非凡扭蛋": {
            "type": "switch",
            "default_case": "No",
            "cases": [
                {
                    "name": "Yes",
                    "pipeline_override": {
                        "ShoppingCoinGachaAnomalyGacha": {
                            "enabled": true
                        }
                    }
                },
                {
                    "name": "No",
                    "pipeline_override": {
                        "ShoppingCoinGachaAnomalyGacha": {
                            "enabled": false
                        }
                    }
                }
            ],
            "label": "$购买非凡扭蛋"
        },
        "购买活动扭蛋": {
            "type": "switch",
            "default_case": "No",
            "cases": [
                {
                    "name": "Yes",
                    "pipeline_override": {
                        "ShoppingCoinGachaActivityGacha": {
                            "enabled": true
                        }
                    }
                },
                {
                    "name": "No",
                    "pipeline_override": {
                        "ShoppingCoinGachaActivityGacha": {
                            "enabled": false
                        }
                    }
                }
            ],
            "label": "$购买活动扭蛋"
        },
        "启用金币兑换": {
            "type": "switch",
            "default_case": "Yes",
            "cases": [
                {
                    "name": "Yes",
                    "pipeline_override": {
                        "ShoppingDailyExchangeMoneyController": {
                            "next": "ShoppingDailyExchangeMoney"
                        }
                    },
                    "option": [
                        "金币兑换列表"
                    ]
                },
                {
                    "name": "No",
                    "pipeline_override": {
                        "ShoppingDailyExchangeMoneyController": {
                            "next": "ShoppingDailyExchangeAPController"
                        }
                    }
                }
            ],
            "label": "$启用金币兑换"
        },
        "启用AP兑换": {
            "type": "switch",
            "default_case": "No",
            "cases": [
                {
                    "name": "Yes",
                    "pipeline_override": {
                        "ShoppingDailyExchangeAPController": {
                            "next": "ShoppingDailyExchangeAPStart"
                        }
                    },
                    "option": [
                        "AP兑换列表"
                    ]
                },
                {
                    "name": "No",
                    "pipeline_override": {
                        "ShoppingDailyExchangeAPController": {
                            "next": "BackHome"
                        }
                    }
                }
            ],
            "label": "$启用AP兑换"
        },
        "金币兑换免费刷新": {
            "type": "switch",
            "default_case": "Yes",
            "cases": [
                {
                    "name": "Yes",
                    "pipeline_override": {
                        "ShoppingFreeRefresh": {
                            "enabled": true
                        }
                    }
                },
                {
                    "name": "No",
                    "pipeline_override": {
                        "ShoppingFreeRefresh": {
                            "enabled": false
                        }
                    }
                }
            ],
            "label": "$金币兑换免费刷新"
        },
